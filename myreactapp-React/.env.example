# Copy to .env.local for local dev, or set on Railway (SMART-MONITORING service only).
# Laravel public origin only — no trailing slash, no /api suffix.
REACT_APP_API_BASE=https://your-laravel-service.up.railway.app

# On Railway you can reference the backend service public hostname (replace service name):
# REACT_APP_API_BASE=https://${{ elegant-sparkle.RAILWAY_PUBLIC_DOMAIN }}
