APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=example_app
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Railway: with BREVO_API_KEY, entrypoint maps Laravel MAIL_* to smtp-relay.brevo.com (real inbox delivery).
# MAIL_FROM_ADDRESS = verified sender in Brevo. If SMTP auth fails, set BREVO_SMTP_LOGIN to your Brevo account email
# and BREVO_SMTP_KEY to the SMTP password from Brevo → SMTP & API (can differ from the REST API key).
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=
# BREVO_SMTP_LOGIN=
# BREVO_SMTP_KEY=
# Brevo 401 + authorised_ips: in Brevo → SMTP & API → API keys → your key → disable IP restriction (Railway IPs are not static).
# EMAIL_SKIP_BREVO_SMTP_ON_RAILWAY=true skips Brevo SMTP relay on Railway after REST fails (587 often times out there).
# RESEND_API_KEY= (resend.com) HTTPS transactional mail on Railway when Brevo IP-allowlists your server; verify your From domain in Resend.
# RAILWAY_TRY_RESEND_FIRST=true (default) tries Resend before Brevo when both keys exist on Railway.

# When email fails, return verification_code in JSON (default true so login always works). Set false to hide code.
# AUTH_LOGIN_CODE_FALLBACK=false

# Resend OTP: true = wait for real SMTP result (honest email_sent in API). false = legacy optimistic async (faster HTTP, may lie about delivery).
# VERIFICATION_RESEND_SYNC=true

# First login /validate-email: true (default) = wait for mail so email_sent is honest. false = async afterResponse (misleading email_sent=true if mail fails).
# VERIFICATION_EMAIL_SYNC=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
