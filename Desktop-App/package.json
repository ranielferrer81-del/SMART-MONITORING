{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "1.0.4",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron dist-electron/main.js\"",
    "dev:web": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron dist-electron/main.js",
    "build": "npm run build:web && npm run build:electron",
    "build:web": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/write-electron-build-config.cjs && node -e \"require('fs').copyFileSync('electron/monitoring-server.cjs','dist-electron/monitoring-server.cjs')\"",
    "build:app": "npm run build && electron-builder",
    "electron": "electron .",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@supabase/supabase-js": "^2.57.4",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "default-gateway": "^7.2.2",
    "express": "^5.2.1",
    "framer-motion": "^12.23.25",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-spring": "^10.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "electron-squirrel-startup": "^1.0.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.example.vite-react-desktop",
    "productName": "Desktop Login App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
