# Copy this file to ".env" in the Desktop-App folder (same folder as package.json).
# Vite reads VITE_* at dev/build time — rebuild the app after changing this.
#
# Railway Laravel API (no trailing slash):
VITE_API_BASE_URL=https://smart-monitoring-production.up.railway.app

# Local development:
# VITE_API_BASE_URL=http://127.0.0.1:8000
