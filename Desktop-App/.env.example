# Copy this file to ".env" in the Desktop-App folder (same folder as package.json).
# Vite reads VITE_* at dev/build time — rebuild the app after changing this.
#
# Backend origin only (no trailing slash). Do not add /api — axios uses /api/... paths; a trailing /api is stripped if present.
#
# Railway: use the Laravel backend service URL (in a browser, /health must return JSON with "status":"ok" and "php":"8.x…").
# If you use the React frontend URL here, /api/validate-email returns 404 and login will fail.
# Must match public/api-base.json and myreactapp-React/public/railway-fallback.json
# VITE_API_BASE_URL=https://your-laravel-service.up.railway.app
VITE_API_BASE_URL=https://elegant-sparkle-production-97fc.up.railway.app

# Local development (same machine or LAN IP to Laravel):
# VITE_API_BASE_URL=http://127.0.0.1:8000
# VITE_API_BASE_URL=http://192.168.1.5:8000
