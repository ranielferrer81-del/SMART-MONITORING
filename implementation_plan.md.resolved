gateway_ip      VARCHAR(45)  UNIQUE   -- e.g., "192.168.2.1"
laboratory_room VARCHAR(255)          -- e.g., "Laboratory 2"
description     VARCHAR(255) NULL     -- e.g., "3rd floor east wing"
```

